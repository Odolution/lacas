<odoo>
<record id="view_move_form_inherit" model="ir.ui.view">
            <field name="name">account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account_edi.view_move_form_inherit"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@id='edi_documents']" position="after">
                    <page name="report fields" string="Extra Information" attrs="{'invisible': [('move_type', 'in', ['entry','out_refund','in_invoice','in_refund'])], 'required': [('move_type', '=', 'out_invoice')]}">
                        <group>
                            <group>
                            <field name="computer"/>
                            <field name="library"/>
                            <field name="utility"/>
                            <field name="art"/>
                            <field name="biology"/>
                            <field name="chemistry"/>
                            <field name="physics"/>
                            <field name="computing"/>
                            <field name="classphoto"/>
                            <field name="collegemagazine"/>
                            <field name="dc"/>
                            <field name="ec"/>
                            <field name="farewell"/>
                            <field name="gatepass"/>
                            <field name="idcard"/>
                            <field name="idcardfine"/>
                            <field name="latecoming"/>
                            <field name="latefee"/>
                            <field name="libfine"/>
                            <field name="mnf"/>
                           

                            </group>    
                            <group>
                            <field name="mobfine"/>
                            <field name="news"/>
                            <field name="paragon"/>
                            <field name="books"/>
                            <field name="pcopy"/>
                            <field name="photo"/>
                            <field name="scarf"/>
                            <field name="sportd"/>
                            <field name="stationary"/>
                            <field name="welcome"/>
                            <field name="workbook"/>
                            <field name="uniform"/>
                            <field name="continuation"/>
                            </group>
                    </group>   
                    </page>
                </xpath>
            </field>
        </record>
</odoo>