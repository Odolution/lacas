<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_book_day_excel" model="ir.ui.view">
        <field name="name">view.sale.book.day.excel </field>
        <field name="model">sale.day.book.report.excel</field>
        <field name="arch" type="xml">
        <form string="Generate Excel File">
            <group>
                <field name="file_name" invisible="1" />
                <field name="excel_file" readonly="1" filename="file_name" />
            </group>
            <footer>
                <button string="Cancel" class="oe_link" special="cancel" />
            </footer>
        </form>
        </field>
    </record>
    <menuitem id="menu_utilisation_report" name="Security Amount Report" action="action_security_amount_report" parent="account.account_report_folder" sequence="3" />

</odoo>